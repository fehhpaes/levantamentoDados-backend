# ===========================================
# SPORTS DATA ANALYTICS - ENVIRONMENT CONFIG
# ===========================================

# Application
DEBUG=false
APP_NAME="Sports Data Analytics"
APP_VERSION="1.0.0"
ENVIRONMENT=production

# Security (REQUIRED - Generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_change_in_production
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (MongoDB Atlas)
# Format: mongodb+srv://username:password@cluster.mongodb.net/database?appName=yourApp
MONGODB_URL=mongodb+srv://admin:admin@prjbet.8gassal.mongodb.net/?appName=prjBet
MONGODB_DATABASE=sports_data

# Redis (Optional - for cache)
# Leave empty if not using Redis
REDIS_URL=
CACHE_TTL=300

# CORS (comma-separated origins)
# Production: Add your Vercel frontend URL
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app

# ===========================================
# EXTERNAL APIS (Optional)
# ===========================================

# Football-Data.org (https://www.football-data.org/)
FOOTBALL_DATA_API_KEY=

# The Odds API (https://the-odds-api.com/)
THE_ODDS_API_KEY=

# API-Sports (https://api-sports.io/)
API_SPORTS_KEY=

# ===========================================
# NOTIFICATIONS (Optional)
# ===========================================

# Telegram Bot (Create via @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=SportsAnalyticsBot

# Email SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@sportsanalytics.com
SMTP_FROM_NAME=Sports Analytics
SMTP_USE_TLS=true

# ===========================================
# MONITORING & LOGGING (Optional)
# ===========================================

# Sentry (Error Tracking)
SENTRY_DSN=

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ===========================================
# SCRAPING SETTINGS
# ===========================================

SCRAPING_DELAY=1.0
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
MAX_CONCURRENT_REQUESTS=5

# ===========================================
# RENDER.COM SPECIFIC (if using Render)
# ===========================================
# PORT is automatically set by Render
# WEB_CONCURRENCY for Gunicorn workers

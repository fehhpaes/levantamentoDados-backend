# ===========================================
# SPORTS DATA ANALYTICS - ENVIRONMENT CONFIG
# ===========================================

# Application
DEBUG=false
APP_NAME="Sports Data Analytics"
APP_VERSION="1.0.0"
ENVIRONMENT=production

# Security (REQUIRED - Generate with: openssl rand -hex 32)
SECRET_KEY=your_secret_key_here_change_in_production
JWT_SECRET_KEY=your_jwt_secret_key_here
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database (PostgreSQL)
# Local: postgresql+asyncpg://postgres:postgres@localhost:5432/sports_data
# Render: Use the Internal Database URL provided by Render
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
DATABASE_ECHO=false

# Redis (for cache and Celery)
# Local: redis://localhost:6379/0
# Render: Use Redis add-on URL
REDIS_URL=redis://localhost:6379/0
CACHE_TTL=300

# Celery (Background Tasks)
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# CORS (comma-separated origins)
# Production: Add your Vercel frontend URL
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-app.vercel.app

# ===========================================
# EXTERNAL APIS
# ===========================================

# Football-Data.org (https://www.football-data.org/)
FOOTBALL_DATA_API_KEY=your_key_here

# The Odds API (https://the-odds-api.com/)
THE_ODDS_API_KEY=your_key_here

# API-Sports (https://api-sports.io/)
API_SPORTS_KEY=your_key_here

# ===========================================
# NOTIFICATIONS
# ===========================================

# Telegram Bot (Create via @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=YourBotUsername

# Email SMTP (Gmail example)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM_EMAIL=noreply@sportsanalytics.com
SMTP_FROM_NAME=Sports Analytics
SMTP_USE_TLS=true

# Push Notifications (Web Push VAPID keys)
VAPID_PUBLIC_KEY=your_public_key
VAPID_PRIVATE_KEY=your_private_key
VAPID_CLAIMS_EMAIL=mailto:admin@sportsanalytics.com

# ===========================================
# MONITORING & LOGGING
# ===========================================

# Sentry (Error Tracking)
SENTRY_DSN=your_sentry_dsn_here

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ===========================================
# SCRAPING SETTINGS
# ===========================================

SCRAPING_DELAY=1.0
USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36
MAX_CONCURRENT_REQUESTS=5

# ===========================================
# RENDER.COM SPECIFIC (if using Render)
# ===========================================
# PORT is automatically set by Render
# WEB_CONCURRENCY for Gunicorn workers
